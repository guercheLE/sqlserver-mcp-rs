# SQL Server host (or host:port -- see SQL_PORT below for the default when omitted).
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_URL=
# One of: sql_server, windows, azure_ad -- see docs/sqlserver-eda-openapi-pipeline/README.md's
# `securitySchemes` documentation for what each mode requires of the target instance.
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_AUTH_METHOD=sql_server
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_SQL_PORT=1433
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_POOL_MAX_SIZE=10
# Trust the server's TLS certificate without CA verification -- on by default
# for a local Docker/dev instance with a self-signed cert; set to false for a
# production instance with a real CA-signed cert.
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_TRUST_SERVER_CERT=true

# sql_server / windows auth:
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_USERNAME=
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_PASSWORD=

# azure_ad auth (client-credentials grant):
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_CLIENT_ID=
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_CLIENT_SECRET=
SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_TENANT_ID=

SQL_SERVER_2025_MASTER_MSDB_SANDBOX_COMBINED_CATALOG_LOG_LEVEL=info
